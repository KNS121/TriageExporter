{
  "index_patterns": ["triage-dlllist"],
  "priority": 100,
  "template": {
    "mappings": {
      "properties": {
        "ModuleName": { "type": "keyword" },
        "TimeLine":   { "type": "date" },
        "Name":       { "type": "keyword" },
        "ProcPath":   { "type": "keyword" },
        "PID":        { "type": "integer" },
        "SourceFile": { "type": "keyword" },
        "DLLList":    { "type": "flattened" }
      }
    }
  }
}